{
  "profile_name": "xquality_machine32",
  "description": "XQuality Machine 32 alarm-table profile. Keeps Machine-32 assumptions outside core NeoOLAF layers.",
  "language": {
    "source": "fr",
    "target": "en",
    "translate": false,
    "llm_translate_inside_extraction": true
  },
  "chunking": {
    "strategies": ["fixed", "page", "subsection", "table"],
    "preferred_unit_for_extraction": "table",
    "chunk_size": 1500,
    "overlap": 200,
    "subsection_patterns": [
      "(?P<section>\\d+\\.\\d+\\.\\d+)\\s+Alarme\\s+n[°o]\\s*(?P<alarm_no>\\d+)"
    ]
  },
  "table_extraction": {
    "enabled": true,
    "table_type": "alarm_table",
    "field_aliases": {
      "alarm_no": ["Alarme n°", "Alarme no", "Alarm No.", "N° Alarme", "N° Alarme"],
      "alarm_label": ["texte", "text", "alarm text", "libellé"],
      "effect": ["effet", "effect", "effects"],
      "cause": ["cause", "causes"],
      "intervention": ["intervention", "action", "actions", "troubleshooting", "strategy"],
      "responsible": ["chargé de l’intervention", "chargé de l'intervention", "responsible", "handled by"],
      "reference": ["référence", "reference", "schema", "schéma", "diagram"]
    }
  },
  "relations": {
    "allowed": ["TRIGGERS", "CAUSES", "REQUIRES", "HANDLED_BY", "REFERENCES"]
  },
  "field_to_relation": {
    "cause": "TRIGGERS",
    "effect": "CAUSES",
    "intervention": "REQUIRES",
    "responsible": "HANDLED_BY",
    "reference": "REFERENCES"
  },
  "triplet_type_by_relation": {
    "TRIGGERS": "Cause → Alarm",
    "CAUSES": "Alarm → Effect",
    "REQUIRES": "Alarm → Intervention",
    "HANDLED_BY": "Alarm → Responsible",
    "REFERENCES": "Alarm → Diagram"
  },
  "triple_schema": {
    "head_col": "Node 1",
    "relation_col": "RELATION",
    "tail_col": "Node 2",
    "metadata": {
      "alarm_no": "Alarm No.",
      "category": "Category",
      "triplet_type": "Triplet Type"
    }
  },
  "defaults": {
    "category": "PLC Alarm"
  },
  "layers": {
    "layer01_linguistic_expression_extraction": {
      "strategy": "alarm_table_record",
      "input_unit": "table"
    },
    "layer05_candidate_triple_generation": {
      "strategy": "alarm_record_to_triples"
    }
  },
  "prompts": {
    "layer01_linguistic_expression_extraction": "xquality_machine32/layer01_alarm_table_record_extraction.md",
    "layer05_candidate_triple_generation": "xquality_machine32/layer05_alarm_record_to_triples.md"
  },
  "rag": {
    "allowed_spaces": {
      "layer01_linguistic_expression_extraction": ["source_document", "table_context"],
      "layer05_candidate_triple_generation": ["source_document", "project_guidelines", "relation_mapping"],
      "layer10_validation_reasoning": ["source_document", "ontology", "generated_triples"]
    }
  },
  "evaluation": {
    "profile_name": "xquality_loose",
    "anchor_fields": ["alarm_no"],
    "strict_relation_match": true
  }
}
