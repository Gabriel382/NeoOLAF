    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Action -->

    <owl:Class rdf:about="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Action">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="en">An action is an operation or intervention performed in response to a detected situation in the manufacturing system.</rdfs:comment>
        <rdfs:label xml:lang="en">Action</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Cause -->

    <owl:Class rdf:about="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Cause">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="en">A cause is a factor or event responsible for the occurrence of a situation in the manufacturing system.</rdfs:comment>
        <rdfs:label xml:lang="en">Cause</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Cell -->

    <owl:Class rdf:about="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Cell">
        <rdfs:subClassOf rdf:resource="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#ManufacturingFacility"/>
        <rdfs:comment xml:lang="en">A manufacturing cell is a group of workstations organized to perform a particular manufacturing task.</rdfs:comment>
        <rdfs:label xml:lang="en">Manufacturing Cell</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Constraint -->

    <owl:Class rdf:about="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Constraint">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="en">A constraint is a condition or rule that restricts or defines acceptable states of a process, resource, or situation.</rdfs:comment>
        <rdfs:label xml:lang="en">Constraint</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticweb.org/STEaMINg/ContextOntology-COInd4#HumanProcess -->

    <owl:Class rdf:about="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#HumanProcess">
        <rdfs:subClassOf rdf:resource="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Process"/>
        <rdfs:comment xml:lang="en">A human process is a process primarily performed by human operators within the manufacturing environment.</rdfs:comment>
        <rdfs:label xml:lang="en">Human Process</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Line -->

    <owl:Class rdf:about="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Line">
        <rdfs:subClassOf rdf:resource="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#ManufacturingFacility"/>
        <rdfs:comment xml:lang="en">A production line is a group of manufacturing cells arranged to carry out a sequence of production tasks.</rdfs:comment>
        <rdfs:label xml:lang="en">Production Line</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticweb.org/STEaMINg/ContextOntology-COInd4#LogisticProcess -->

    <owl:Class rdf:about="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#LogisticProcess">
        <rdfs:subClassOf rdf:resource="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Process"/>
        <rdfs:comment xml:lang="en">A logistic process is a process related to the movement, storage, or management of materials or products.</rdfs:comment>
        <rdfs:label xml:lang="en">Logistic Process</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Machine -->

    <owl:Class rdf:about="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Machine">
        <rdfs:subClassOf rdf:resource="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#ManufacturingFacility"/>
        <rdfs:comment xml:lang="en">A machine is a device used to perform a manufacturing task, either autonomously or with human intervention.</rdfs:comment>
        <rdfs:label xml:lang="en">Machine</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Manager -->

    <owl:Class rdf:about="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Manager">
        <rdfs:subClassOf rdf:resource="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Staff"/>
        <rdfs:comment xml:lang="en">A manager is a person responsible for supervising manufacturing operations and responding to detected situations.</rdfs:comment>
        <rdfs:label xml:lang="en">Manager</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticweb.org/STEaMINg/ContextOntology-COInd4#ManufacturingFacility -->

    <owl:Class rdf:about="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#ManufacturingFacility">
        <rdfs:subClassOf rdf:resource="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Resource"/>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/sosa/Platform"/>
        <rdfs:comment xml:lang="en">A manufacturing facility is a physical environment where manufacturing processes take place.</rdfs:comment>
        <rdfs:label xml:lang="en">Manufacturing Facility</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticweb.org/STEaMINg/ContextOntology-COInd4#ManufacturingProcess -->

    <owl:Class rdf:about="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#ManufacturingProcess">
        <rdfs:subClassOf rdf:resource="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Process"/>
        <rdfs:comment xml:lang="en">A manufacturing process is an industrial process carried out within a manufacturing facility to produce or transform products.</rdfs:comment>
        <rdfs:label xml:lang="en">Manufacturing Process</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Operator -->

    <owl:Class rdf:about="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Operator">
        <rdfs:subClassOf rdf:resource="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Staff"/>
        <rdfs:comment xml:lang="en">An operator is a worker responsible for operating machines or performing production tasks.</rdfs:comment>
        <rdfs:label xml:lang="en">Operator</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Part -->

    <owl:Class rdf:about="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Part">
        <rdfs:subClassOf rdf:resource="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Product"/>
        <rdfs:comment xml:lang="en">A part is a component or piece used in the assembly or production of a product.</rdfs:comment>
        <rdfs:label xml:lang="en">Part</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Process -->

    <owl:Class rdf:about="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Process">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="en">A process is an activity that transforms inputs into outputs.</rdfs:comment>
        <rdfs:label xml:lang="en">Process</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Product -->

    <owl:Class rdf:about="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Product">
        <rdfs:subClassOf rdf:resource="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Resource"/>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/sosa/Platform"/>
        <rdfs:comment xml:lang="en">A product is an item produced or processed during manufacturing operations.</rdfs:comment>
        <rdfs:label xml:lang="en">Product</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Resource -->

    <owl:Class rdf:about="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Resource">
        <owl:equivalentClass rdf:resource="http://www.w3.org/ns/sosa/Platform"/>
        <rdfs:subClassOf rdf:resource="http://www.opengis.net/ont/geosparql#Feature"/>
        <rdfs:comment xml:lang="en">A resource is an entity used during manufacturing processes, such as a machine, material, or human resource.</rdfs:comment>
        <rdfs:label xml:lang="en">Resource</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Situation -->

    <owl:Class rdf:about="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Situation">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="en">A situation is a contextual state describing conditions in a manufacturing environment based on observations, processes, and contextual factors.</rdfs:comment>
        <rdfs:label xml:lang="en">Situation</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Situation-S1 -->

    <owl:Class rdf:about="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Situation-S1">
        <rdfs:subClassOf rdf:resource="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Situation"/>
        <rdfs:comment xml:lang="en">Situation S1 is a specialized situation class representing a specific contextual state in the manufacturing system.</rdfs:comment>
        <rdfs:label xml:lang="en">Situation S1</rdfs:label>
    </owl:Class>
    


