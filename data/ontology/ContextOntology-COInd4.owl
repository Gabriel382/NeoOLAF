    </owl:Class>
    


    <!-- http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Situation-S6 -->

    <owl:Class rdf:about="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Situation-S6">
        <rdfs:subClassOf rdf:resource="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Situation"/>
        <rdfs:comment xml:lang="en">Situation S6 is a specialized situation class representing a specific contextual state in the manufacturing system.</rdfs:comment>
        <rdfs:label xml:lang="en">Situation S6</rdfs:label>
    </owl:Class>
    


