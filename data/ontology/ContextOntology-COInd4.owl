<?xml version="1.0"?>
<rdf:RDF xmlns="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#"
     xml:base="http://semanticweb.org/STEaMINg/ContextOntology-COInd4"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:sosa="http://www.w3.org/ns/sosa/"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:time="http://www.w3.org/2006/time#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:ContextOntology-COInd4="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#">
    <owl:Ontology rdf:about="http://semanticweb.org/STEaMINg/ContextOntology-COInd4">
        <rdfs:comment xml:lang="en">Ontology describing contextual situations in industrial environments, integrating sensor observations (SOSA/SSN), spatial context (GeoSPARQL), and temporal relations (OWL-Time).</rdfs:comment>
        <rdfs:label xml:lang="en">COInd Context Ontology for Industrial Situations</rdfs:label>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.opengis.net/ont/geosparql#gmlLiteral -->

    <rdfs:Datatype rdf:about="http://www.opengis.net/ont/geosparql#gmlLiteral"/>
    


    <!-- http://www.opengis.net/ont/geosparql#wktLiteral -->

    <rdfs:Datatype rdf:about="http://www.opengis.net/ont/geosparql#wktLiteral"/>
    


    <!-- https://www.w3.org/TR/xmlschema11-2/#dateTimeStamp -->

    <rdfs:Datatype rdf:about="https://www.w3.org/TR/xmlschema11-2/#dateTimeStamp"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://semanticweb.org/STEaMINg/ContextOntology-COInd4#associatedConstraint -->

    <owl:ObjectProperty rdf:about="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#associatedConstraint">
        <rdfs:domain rdf:resource="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Situation"/>
        <rdfs:range rdf:resource="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Constraint"/>
        <rdfs:comment xml:lang="en">Relates a process, resource, or situation to a constraint that defines acceptable operational conditions.</rdfs:comment>
        <rdfs:label xml:lang="en">associated constraint</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://semanticweb.org/STEaMINg/ContextOntology-COInd4#concernBy -->

    <owl:ObjectProperty rdf:about="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#concernBy">
        <rdfs:domain rdf:resource="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Resource"/>
        <rdfs:range rdf:resource="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Situation"/>
        <rdfs:comment xml:lang="en">Relates a situation or event to an entity, such as a machine, process, or product, that it concerns.</rdfs:comment>
        <rdfs:label xml:lang="en">concerned by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://semanticweb.org/STEaMINg/ContextOntology-COInd4#definedOn -->

    <owl:ObjectProperty rdf:about="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#definedOn">
        <owl:inverseOf rdf:resource="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#definedOn_1"/>
        <rdfs:domain rdf:resource="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Constraint"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/sosa/ObservableProperty"/>
        <rdfs:comment xml:lang="en">Relates a situation or property to the entity or context element on which it is defined.</rdfs:comment>
        <rdfs:label xml:lang="en">defined on</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://semanticweb.org/STEaMINg/ContextOntology-COInd4#definedOn_1 -->

    <owl:ObjectProperty rdf:about="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#definedOn_1">
        <rdfs:comment xml:lang="en">Relates an entity or context element to the situation or property for which it is defined.</rdfs:comment>
        <rdfs:label xml:lang="en">is defined for</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://semanticweb.org/STEaMINg/ContextOntology-COInd4#hasCause -->

    <owl:ObjectProperty rdf:about="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#hasCause">
        <rdfs:domain rdf:resource="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Situation"/>
        <rdfs:range rdf:resource="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Cause"/>
        <rdfs:comment xml:lang="en">Relates a situation to the cause responsible for triggering or explaining it.</rdfs:comment>
        <rdfs:label xml:lang="en">has cause</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://semanticweb.org/STEaMINg/ContextOntology-COInd4#hasDuration -->

    <owl:ObjectProperty rdf:about="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#hasDuration">
        <rdfs:domain rdf:resource="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Process"/>
        <rdfs:range rdf:resource="http://www.w3.org/2006/time#TemporalEntity"/>
        <rdfs:comment xml:lang="en">Relates an event, process, or situation to the temporal interval during which it occurs.</rdfs:comment>
        <rdfs:label xml:lang="en">has duration</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://semanticweb.org/STEaMINg/ContextOntology-COInd4#hasObservableProperty -->

    <owl:ObjectProperty rdf:about="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#hasObservableProperty">
        <rdfs:domain rdf:resource="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Resource"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/sosa/ObservableProperty"/>
        <rdfs:comment xml:lang="en">Relates an entity in the manufacturing system to a property that can be observed by sensors.</rdfs:comment>
        <rdfs:label xml:lang="en">has observable property</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://semanticweb.org/STEaMINg/ContextOntology-COInd4#hasObservation -->

    <owl:ObjectProperty rdf:about="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#hasObservation">
        <rdfs:domain rdf:resource="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Situation"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/sosa/Observation"/>
        <rdfs:comment xml:lang="en">Relates a situation to an observation associated with it.</rdfs:comment>
        <rdfs:label xml:lang="en">has observation</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://semanticweb.org/STEaMINg/ContextOntology-COInd4#hasTime -->

    <owl:ObjectProperty rdf:about="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#hasTime">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/sosa/Observation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2006/time#TemporalEntity"/>
        <rdfs:comment xml:lang="en">Relates an observation to the temporal entity that represents when it occurred.</rdfs:comment>
        <rdfs:label xml:lang="en">has time</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://semanticweb.org/STEaMINg/ContextOntology-COInd4#isInSituation -->

    <owl:ObjectProperty rdf:about="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#isInSituation">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/sosa/Observation"/>
        <rdfs:range rdf:resource="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Situation"/>
        <rdfs:comment xml:lang="en">Relates an observation to the situation with which it is associated.</rdfs:comment>
        <rdfs:label xml:lang="en">is in situation</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://semanticweb.org/STEaMINg/ContextOntology-COInd4#isInlocation -->

    <owl:ObjectProperty rdf:about="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#isInlocation">
        <rdfs:domain rdf:resource="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Resource"/>
        <rdfs:range rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:comment xml:lang="en">Relates a resource to the spatial object in which it is located.</rdfs:comment>
        <rdfs:label xml:lang="en">is in location</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://semanticweb.org/STEaMINg/ContextOntology-COInd4#isPartOf -->

    <owl:ObjectProperty rdf:about="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#isPartOf">
        <rdfs:domain rdf:resource="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#ManufacturingFacility"/>
        <rdfs:range rdf:resource="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#ManufacturingFacility"/>
        <rdfs:comment xml:lang="en">Relates an entity to a larger entity of which it is a component.</rdfs:comment>
        <rdfs:label xml:lang="en">is part of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://semanticweb.org/STEaMINg/ContextOntology-COInd4#locatedIn -->

    <owl:ObjectProperty rdf:about="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#locatedIn">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/sosa/Sensor"/>
        <rdfs:range rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:comment xml:lang="en">Relates a sensor to the spatial object in which it is located.</rdfs:comment>
        <rdfs:label xml:lang="en">located in</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://semanticweb.org/STEaMINg/ContextOntology-COInd4#operates -->

    <owl:ObjectProperty rdf:about="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#operates">
        <rdfs:domain rdf:resource="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Staff"/>
        <rdfs:range rdf:resource="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#ManufacturingFacility"/>
        <rdfs:comment xml:lang="en">Relates a staff member or operator to the machine or workstation that they operate.</rdfs:comment>
        <rdfs:label xml:lang="en">operates</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://semanticweb.org/STEaMINg/ContextOntology-COInd4#performsPorcess -->

    <owl:ObjectProperty rdf:about="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#performsPorcess">
        <rdfs:domain rdf:resource="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Resource"/>
        <rdfs:range rdf:resource="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Process"/>
        <rdfs:comment xml:lang="en">Relates a resource to a process that it performs or supports.</rdfs:comment>
        <rdfs:label xml:lang="en">performs process</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://semanticweb.org/STEaMINg/ContextOntology-COInd4#requiresAction -->

    <owl:ObjectProperty rdf:about="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#requiresAction">
        <rdfs:domain rdf:resource="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Situation"/>
        <rdfs:range rdf:resource="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Action"/>
        <rdfs:comment xml:lang="en">Relates a situation to an action that should be performed in response to it.</rdfs:comment>
        <rdfs:label xml:lang="en">requires action</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://semanticweb.org/STEaMINg/ContextOntology-COInd4#situationTime -->

    <owl:ObjectProperty rdf:about="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#situationTime">
        <rdfs:domain rdf:resource="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Situation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2006/time#Interval"/>
        <rdfs:comment xml:lang="en">Relates a situation to the temporal entity that represents when it occurs.</rdfs:comment>
        <rdfs:label xml:lang="en">situation time</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.opengis.net/ont/geosparql#hasGeometry -->

    <owl:ObjectProperty rdf:about="http://www.opengis.net/ont/geosparql#hasGeometry">
        <rdfs:domain rdf:resource="http://www.opengis.net/ont/geosparql#Feature"/>
        <rdfs:range rdf:resource="http://www.opengis.net/ont/geosparql#Geometry"/>
        <rdfs:comment xml:lang="en">Relates a feature to the geometry that represents its spatial extent.</rdfs:comment>
        <rdfs:label xml:lang="en">has geometry</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.opengis.net/ont/geosparql#rcc8dc -->

    <owl:ObjectProperty rdf:about="http://www.opengis.net/ont/geosparql#rcc8dc">
        <rdfs:domain rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:range rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:comment xml:lang="en">Relates two spatial regions that are disconnected and share no common point.</rdfs:comment>
        <rdfs:label xml:lang="en">disconnected</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.opengis.net/ont/geosparql#rcc8ec -->

    <owl:ObjectProperty rdf:about="http://www.opengis.net/ont/geosparql#rcc8ec">
        <rdfs:domain rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:range rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:comment xml:lang="en">Relates two spatial regions that touch along their boundary but whose interiors do not overlap.</rdfs:comment>
        <rdfs:label xml:lang="en">externally connected</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.opengis.net/ont/geosparql#rcc8eq -->

    <owl:ObjectProperty rdf:about="http://www.opengis.net/ont/geosparql#rcc8eq">
        <rdfs:domain rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:range rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:comment xml:lang="en">Relates two spatial regions that have exactly the same spatial extent.</rdfs:comment>
        <rdfs:label xml:lang="en">equals</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.opengis.net/ont/geosparql#rcc8ntpp -->

    <owl:ObjectProperty rdf:about="http://www.opengis.net/ont/geosparql#rcc8ntpp">
        <rdfs:domain rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:range rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:comment xml:lang="en">Relates a spatial region that is completely inside another region without touching its boundary.</rdfs:comment>
        <rdfs:label xml:lang="en">non-tangential proper part</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.opengis.net/ont/geosparql#rcc8ntppi -->

    <owl:ObjectProperty rdf:about="http://www.opengis.net/ont/geosparql#rcc8ntppi">
        <rdfs:domain rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:range rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:comment xml:lang="en">Relates a spatial region that completely contains another region whose boundary it does not touch.</rdfs:comment>
        <rdfs:label xml:lang="en">non-tangential proper part inverse</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.opengis.net/ont/geosparql#rcc8po -->

    <owl:ObjectProperty rdf:about="http://www.opengis.net/ont/geosparql#rcc8po">
        <rdfs:domain rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:range rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:comment xml:lang="en">Relates two spatial regions whose interiors overlap, while neither region contains the other.</rdfs:comment>
        <rdfs:label xml:lang="en">partially overlapping</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.opengis.net/ont/geosparql#rcc8tpp -->

    <owl:ObjectProperty rdf:about="http://www.opengis.net/ont/geosparql#rcc8tpp">
        <rdfs:domain rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:range rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:comment xml:lang="en">Relates a spatial region that is inside another region and touches its boundary.</rdfs:comment>
        <rdfs:label xml:lang="en">tangential proper part</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.opengis.net/ont/geosparql#rcc8tppi -->

    <owl:ObjectProperty rdf:about="http://www.opengis.net/ont/geosparql#rcc8tppi">
        <rdfs:domain rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:range rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:comment xml:lang="en">Relates a spatial region that contains another region and touches its boundary.</rdfs:comment>
        <rdfs:label xml:lang="en">tangential proper part inverse</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2006/time#after -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/2006/time#after">
        <rdfs:domain rdf:resource="http://www.w3.org/2006/time#TemporalEntity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2006/time#TemporalEntity"/>
        <rdfs:comment xml:lang="en">Relates a temporal entity that occurs after another temporal entity.</rdfs:comment>
        <rdfs:label xml:lang="en">after</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2006/time#before -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/2006/time#before">
        <rdfs:domain rdf:resource="http://www.w3.org/2006/time#TemporalEntity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2006/time#TemporalEntity"/>
        <rdfs:comment xml:lang="en">Relates a temporal entity that occurs before another temporal entity.</rdfs:comment>
        <rdfs:label xml:lang="en">before</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2006/time#hasBeginning -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/2006/time#hasBeginning">
        <rdfs:domain rdf:resource="http://www.w3.org/2006/time#TemporalEntity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2006/time#Instant"/>
        <rdfs:comment xml:lang="en">Relates a temporal interval to the instant that marks its beginning.</rdfs:comment>
        <rdfs:label xml:lang="en">has beginning</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2006/time#hasEnd -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/2006/time#hasEnd">
        <rdfs:domain rdf:resource="http://www.w3.org/2006/time#TemporalEntity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2006/time#Instant"/>
        <rdfs:comment xml:lang="en">Relates a temporal interval to the instant that marks its end.</rdfs:comment>
        <rdfs:label xml:lang="en">has end</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2006/time#inside -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/2006/time#inside">
        <rdfs:domain rdf:resource="http://www.w3.org/2006/time#Interval"/>
        <rdfs:range rdf:resource="http://www.w3.org/2006/time#Instant"/>
        <rdfs:comment xml:lang="en">Relates a temporal instant or interval that occurs within another interval.</rdfs:comment>
        <rdfs:label xml:lang="en">inside</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2006/time#intervalAfter -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/2006/time#intervalAfter">
        <rdfs:domain rdf:resource="http://www.w3.org/2006/time#Interval"/>
        <rdfs:range rdf:resource="http://www.w3.org/2006/time#Interval"/>
        <rdfs:comment xml:lang="en">Relates a time interval that occurs completely after another interval.</rdfs:comment>
        <rdfs:label xml:lang="en">interval after</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2006/time#intervalBefore -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/2006/time#intervalBefore">
        <rdfs:domain rdf:resource="http://www.w3.org/2006/time#Interval"/>
        <rdfs:range rdf:resource="http://www.w3.org/2006/time#Interval"/>
        <rdfs:comment xml:lang="en">Relates a time interval that occurs completely before another interval.</rdfs:comment>
        <rdfs:label xml:lang="en">interval before</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2006/time#intervalContains -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/2006/time#intervalContains">
        <rdfs:domain rdf:resource="http://www.w3.org/2006/time#Interval"/>
        <rdfs:range rdf:resource="http://www.w3.org/2006/time#Interval"/>
        <rdfs:comment xml:lang="en">Relates a time interval that fully contains another interval.</rdfs:comment>
        <rdfs:label xml:lang="en">interval contains</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2006/time#intervalDisjoint -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/2006/time#intervalDisjoint">
        <rdfs:domain rdf:resource="http://www.w3.org/2006/time#Interval"/>
        <rdfs:range rdf:resource="http://www.w3.org/2006/time#Interval"/>
        <rdfs:comment xml:lang="en">Relates two temporal intervals that do not overlap in time.</rdfs:comment>
        <rdfs:label xml:lang="en">interval disjoint</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2006/time#intervalDuring -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/2006/time#intervalDuring">
        <rdfs:domain rdf:resource="http://www.w3.org/2006/time#Interval"/>
        <rdfs:range rdf:resource="http://www.w3.org/2006/time#Interval"/>
        <rdfs:comment xml:lang="en">Relates an interval that starts after another interval begins and ends before it ends.</rdfs:comment>
        <rdfs:label xml:lang="en">interval during</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2006/time#intervalEquals -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/2006/time#intervalEquals">
        <rdfs:domain rdf:resource="http://www.w3.org/2006/time#Interval"/>
        <rdfs:range rdf:resource="http://www.w3.org/2006/time#Interval"/>
        <rdfs:comment xml:lang="en">Relates two time intervals that have exactly the same temporal extent.</rdfs:comment>
        <rdfs:label xml:lang="en">interval equals</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2006/time#intervalFinishedBy -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/2006/time#intervalFinishedBy">
        <rdfs:domain rdf:resource="http://www.w3.org/2006/time#Interval"/>
        <rdfs:range rdf:resource="http://www.w3.org/2006/time#Interval"/>
        <rdfs:comment xml:lang="en">Relates an interval that ends at the same time as another interval but starts earlier.</rdfs:comment>
        <rdfs:label xml:lang="en">interval finished by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2006/time#intervalFinishes -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/2006/time#intervalFinishes">
        <rdfs:domain rdf:resource="http://www.w3.org/2006/time#Interval"/>
        <rdfs:range rdf:resource="http://www.w3.org/2006/time#Interval"/>
        <rdfs:comment xml:lang="en">Relates an interval that ends at the same time as another interval but starts later.</rdfs:comment>
        <rdfs:label xml:lang="en">interval finishes</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2006/time#intervalIn -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/2006/time#intervalIn">
        <rdfs:domain rdf:resource="http://www.w3.org/2006/time#Interval"/>
        <rdfs:range rdf:resource="http://www.w3.org/2006/time#Interval"/>
        <rdfs:comment xml:lang="en">Relates an interval that is contained within another interval, without requiring both boundaries to coincide.</rdfs:comment>
        <rdfs:label xml:lang="en">interval in</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2006/time#intervalMeets -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/2006/time#intervalMeets">
        <rdfs:domain rdf:resource="http://www.w3.org/2006/time#Interval"/>
        <rdfs:range rdf:resource="http://www.w3.org/2006/time#Interval"/>
        <rdfs:comment xml:lang="en">Relates an interval that ends exactly when another interval begins.</rdfs:comment>
        <rdfs:label xml:lang="en">interval meets</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2006/time#intervalMetBy -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/2006/time#intervalMetBy">
        <rdfs:domain rdf:resource="http://www.w3.org/2006/time#Interval"/>
        <rdfs:range rdf:resource="http://www.w3.org/2006/time#Interval"/>
        <rdfs:comment xml:lang="en">Relates an interval that begins exactly when another interval ends.</rdfs:comment>
        <rdfs:label xml:lang="en">interval met by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2006/time#intervalOverlaps -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/2006/time#intervalOverlaps">
        <rdfs:domain rdf:resource="http://www.w3.org/2006/time#Interval"/>
        <rdfs:range rdf:resource="http://www.w3.org/2006/time#Interval"/>
        <rdfs:comment xml:lang="en">Relates an interval that overlaps another interval without either interval containing the other.</rdfs:comment>
        <rdfs:label xml:lang="en">interval overlaps</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2006/time#intervalStartedBy -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/2006/time#intervalStartedBy">
        <rdfs:domain rdf:resource="http://www.w3.org/2006/time#Interval"/>
        <rdfs:range rdf:resource="http://www.w3.org/2006/time#Interval"/>
        <rdfs:comment xml:lang="en">Relates an interval that starts at the same time as another interval but ends later.</rdfs:comment>
        <rdfs:label xml:lang="en">interval started by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2006/time#intervalStarts -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/2006/time#intervalStarts">
        <rdfs:domain rdf:resource="http://www.w3.org/2006/time#Interval"/>
        <rdfs:range rdf:resource="http://www.w3.org/2006/time#Interval"/>
        <rdfs:comment xml:lang="en">Relates an interval that starts at the same time as another interval but ends sooner.</rdfs:comment>
        <rdfs:label xml:lang="en">interval starts</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/sosa/hasFeatureOfInterest -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/sosa/hasFeatureOfInterest">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/sosa/Observation"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/sosa/FeatureOfInterest"/>
        <rdfs:comment xml:lang="en">Relates an observation to the entity whose property is being observed.</rdfs:comment>
        <rdfs:label xml:lang="en">has feature of interest</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/sosa/hasResult -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/sosa/hasResult">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/sosa/Observation"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/sosa/Result"/>
        <rdfs:comment xml:lang="en">Relates an observation to the result that it produced.</rdfs:comment>
        <rdfs:label xml:lang="en">has result</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/sosa/hosts -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/sosa/hosts">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/sosa/Platform"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/sosa/Sensor"/>
        <rdfs:comment xml:lang="en">Relates a platform to a sensor, actuator, sampler, or platform that it hosts.</rdfs:comment>
        <rdfs:label xml:lang="en">hosts</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/sosa/madeObservation -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/sosa/madeObservation">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/sosa/Sensor"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/sosa/Observation"/>
        <rdfs:comment xml:lang="en">Relates a sensor to an observation that it made.</rdfs:comment>
        <rdfs:label xml:lang="en">made observation</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/sosa/observedProperty -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/sosa/observedProperty">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/sosa/Observation"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/sosa/ObservableProperty"/>
        <rdfs:comment xml:lang="en">Relates an observation to the property that it observes.</rdfs:comment>
        <rdfs:label xml:lang="en">observed property</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/ssn/hasProperty -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/ssn/hasProperty">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/sosa/FeatureOfInterest"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/ssn/Property"/>
        <rdfs:comment xml:lang="en">Relates an entity to one of its properties.</rdfs:comment>
        <rdfs:label xml:lang="en">has property</rdfs:label>
    </owl:ObjectProperty>
    


