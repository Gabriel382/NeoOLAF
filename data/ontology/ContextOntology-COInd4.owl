    <!-- http://semanticweb.org/STEaMINg/ContextOntology-COInd4#hasDescription -->

    <owl:DatatypeProperty rdf:about="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#hasDescription">
        <rdfs:domain rdf:resource="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Constraint"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Links a constraint to its description.</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.opengis.net/ont/geosparql#asGML -->

    <owl:DatatypeProperty rdf:about="http://www.opengis.net/ont/geosparql#asGML">
        <rdfs:domain rdf:resource="http://www.opengis.net/ont/geosparql#Geometry"/>
        <rdfs:range rdf:resource="http://www.opengis.net/ont/geosparql#gmlLiteral"/>
        <rdfs:comment xml:lang="en">Links a geometry to its GML serialization.</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.opengis.net/ont/geosparql#asWKT -->

    <owl:DatatypeProperty rdf:about="http://www.opengis.net/ont/geosparql#asWKT">
        <rdfs:domain rdf:resource="http://www.opengis.net/ont/geosparql#Geometry"/>
        <rdfs:range rdf:resource="http://www.opengis.net/ont/geosparql#wktLiteral"/>
        <rdfs:comment xml:lang="en">Links a geometry to its WKT serialization.</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.w3.org/2006/time#inXSDDateTimeStamp -->

    <owl:DatatypeProperty rdf:about="http://www.w3.org/2006/time#inXSDDateTimeStamp">
        <rdfs:domain rdf:resource="http://www.w3.org/2006/time#Instant"/>
        <rdfs:range rdf:resource="https://www.w3.org/TR/xmlschema11-2/#dateTimeStamp"/>
        <rdfs:comment xml:lang="en">Position of an instant in which the time-zone field is mandatory.</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.w3.org/ns/sosa/hasSimpleResult -->

    <owl:DatatypeProperty rdf:about="http://www.w3.org/ns/sosa/hasSimpleResult">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/sosa/Observation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">Links an obervation to its result, which contains a value representing the value associated with the observed Property.</rdfs:comment>
    </owl:DatatypeProperty>
    


