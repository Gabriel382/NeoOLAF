        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/sosa/Platform"/>
        <rdfs:comment xml:lang="en">Staff is a human agent involved in the operation or supervision of manufacturing processes.</rdfs:comment>
        <rdfs:label xml:lang="en">Staff</rdfs:label>
    </owl:Class>
    


