        <rdfs:subClassOf rdf:resource="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#Staff"/>
        <rdfs:comment xml:lang="en">A technician is a technical specialist responsible for maintaining or repairing equipment.</rdfs:comment>
        <rdfs:label xml:lang="en">Technician</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticweb.org/STEaMINg/ContextOntology-COInd4#WorkStation -->

    <owl:Class rdf:about="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#WorkStation">
        <rdfs:subClassOf rdf:resource="http://semanticweb.org/STEaMINg/ContextOntology-COInd4#ManufacturingFacility"/>
        <rdfs:comment xml:lang="en">A workstation is a physical area in the manufacturing environment where one or more machines or resources are organized to perform a specific task.</rdfs:comment>
        <rdfs:label xml:lang="en">Workstation</rdfs:label>
    </owl:Class>
    


    <!-- http://www.opengis.net/ont/geosparql#Feature -->

    <owl:Class rdf:about="http://www.opengis.net/ont/geosparql#Feature">
        <rdfs:subClassOf rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:comment xml:lang="en">A feature is a spatial entity representing a physical object or location in the manufacturing environment.</rdfs:comment>
        <rdfs:label xml:lang="en">Feature</rdfs:label>
    </owl:Class>
    


    <!-- http://www.opengis.net/ont/geosparql#Geometry -->

    <owl:Class rdf:about="http://www.opengis.net/ont/geosparql#Geometry">
        <rdfs:subClassOf rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:comment xml:lang="en">A geometry is the geometric representation of a spatial feature.</rdfs:comment>
        <rdfs:label xml:lang="en">Geometry</rdfs:label>
    </owl:Class>
    


    <!-- http://www.opengis.net/ont/geosparql#SpatialObject -->

    <owl:Class rdf:about="http://www.opengis.net/ont/geosparql#SpatialObject">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="en">A spatial object is an entity with a spatial extent in the manufacturing environment.</rdfs:comment>
        <rdfs:label xml:lang="en">Spatial Object</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/2006/time#Instant -->

    <owl:Class rdf:about="http://www.w3.org/2006/time#Instant">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2006/time#TemporalEntity"/>
        <rdfs:comment xml:lang="en">An instant is a specific point in time.</rdfs:comment>
        <rdfs:label xml:lang="en">Instant</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/2006/time#Interval -->

    <owl:Class rdf:about="http://www.w3.org/2006/time#Interval">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2006/time#TemporalEntity"/>
        <rdfs:comment xml:lang="en">An interval is a temporal extent with a beginning and an end.</rdfs:comment>
        <rdfs:label xml:lang="en">Interval</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/2006/time#TemporalEntity -->

    <owl:Class rdf:about="http://www.w3.org/2006/time#TemporalEntity">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="en">A temporal entity is a temporal interval or instant used to represent the time of an observation or situation.</rdfs:comment>
        <rdfs:label xml:lang="en">Temporal Entity</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/ns/sosa/FeatureOfInterest -->

    <owl:Class rdf:about="http://www.w3.org/ns/sosa/FeatureOfInterest">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="en">A feature of interest is the entity whose property is being observed.</rdfs:comment>
        <rdfs:label xml:lang="en">Feature of Interest</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/ns/sosa/ObservableProperty -->

    <owl:Class rdf:about="http://www.w3.org/ns/sosa/ObservableProperty">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/ssn/Property"/>
        <rdfs:comment xml:lang="en">An observable property is a property of a feature of interest that can be observed by a sensor.</rdfs:comment>
        <rdfs:label xml:lang="en">Observable Property</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/ns/sosa/Observation -->

    <owl:Class rdf:about="http://www.w3.org/ns/sosa/Observation">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="en">An observation is an event in which a sensor measures or estimates the value of an observable property of a feature of interest.</rdfs:comment>
        <rdfs:label xml:lang="en">Observation</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/ns/sosa/Platform -->

    <owl:Class rdf:about="http://www.w3.org/ns/sosa/Platform">
        <rdfs:subClassOf rdf:resource="http://www.opengis.net/ont/geosparql#Feature"/>
        <rdfs:comment xml:lang="en">A platform is an entity that hosts sensors, actuators, samplers, or other platforms.</rdfs:comment>
        <rdfs:label xml:lang="en">Platform</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/ns/sosa/Result -->

    <owl:Class rdf:about="http://www.w3.org/ns/sosa/Result">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="en">A result is the outcome or value produced by an observation.</rdfs:comment>
        <rdfs:label xml:lang="en">Result</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/ns/sosa/Sensor -->

    <owl:Class rdf:about="http://www.w3.org/ns/sosa/Sensor">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="en">A sensor is a device, agent, or software component that performs observations.</rdfs:comment>
        <rdfs:label xml:lang="en">Sensor</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/ns/ssn/Property -->

    <owl:Class rdf:about="http://www.w3.org/ns/ssn/Property">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="en">A property is a characteristic of an entity that can be observed or measured.</rdfs:comment>
        <rdfs:label xml:lang="en">Property</rdfs:label>
    </owl:Class>
    


