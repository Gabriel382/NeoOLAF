:obs a swrl:Variable .

:op a swrl:Variable .

:Machine a owl:Class ;
    rdfs:label "Machine"@en ;
    rdfs:comment "A machine is a device used to perform a manufacturing task, either autonomously or with human intervention."@en ;
    rdfs:subClassOf :ManufacturingFacility .

:Process a owl:Class ;
    rdfs:label "Process"@en ;
    rdfs:comment "A process is an activity that transforms inputs into outputs."@en ;
    rdfs:subClassOf owl:Thing .

:Cause a owl:Class ;
    rdfs:label "Cause"@en ;
    rdfs:comment "A cause is a factor or event responsible for the occurrence of a situation in the manufacturing system."@en ;
    rdfs:subClassOf owl:Thing .

:Situation-S6 a owl:Class ;
