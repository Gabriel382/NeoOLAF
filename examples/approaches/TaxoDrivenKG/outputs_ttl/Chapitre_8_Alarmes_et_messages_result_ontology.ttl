@prefix : <http://semanticweb.org/STEaMINg/ContextOntology-COInd4#> .
@prefix geo: <http://www.opengis.net/ont/geosparql#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sosa: <http://www.w3.org/ns/sosa/> .
@prefix ssn: <http://www.w3.org/ns/ssn/> .
@prefix swrl: <http://www.w3.org/2003/11/swrl#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix voc: <http://taxodrivenkg-xquality.org/vocab/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://semanticweb.org/STEaMINg/ContextOntology-COInd4> a owl:Ontology ;
    rdfs:label "COInd Context Ontology for Industrial Situations"@en ;
    rdfs:comment "Ontology describing contextual situations in industrial environments, integrating sensor observations (SOSA/SSN), spatial context (GeoSPARQL), and temporal relations (OWL-Time)."@en .

:HumanProcess a owl:Class ;
    rdfs:label "Human Process"@en ;
    rdfs:comment "A human process is a process primarily performed by human operators within the manufacturing environment."@en ;
    rdfs:subClassOf :Process .

:LogisticProcess a owl:Class ;
    rdfs:label "Logistic Process"@en ;
    rdfs:comment "A logistic process is a process related to the movement, storage, or management of materials or products."@en ;
    rdfs:subClassOf :Process .

:M1 a :Machine,
        :ManufacturingFacility,
        :Resource,
        geo:Feature,
        geo:SpatialObject,
        owl:NamedIndividual,
        owl:Thing,
        sosa:Platform ;
    rdfs:label "Machine M1"@en ;
    :hasObservableProperty sosa:C_temp,
        sosa:G_current,
        sosa:OilTemp,
        sosa:T_temp ;
    :isPartOf :PL1 ;
    rdfs:comment "Machine individual representing machine M1 of the production line."@en ;
    sosa:hosts sosa:S_C_temp,
        sosa:S_G_current,
        sosa:S_OilTemp,
        sosa:S_T_temp .

:M2 a :Machine,
        :ManufacturingFacility,
        :Resource,
        geo:Feature,
        geo:SpatialObject,
        owl:NamedIndividual,
        owl:Thing,
        sosa:Platform ;
    rdfs:label "Machine M2"@en ;
    :hasObservableProperty sosa:GB_temp,
        sosa:G_speed ;
    :isPartOf :PL1 ;
    rdfs:comment "Machine individual representing machine M2 of the production line."@en ;
    sosa:hosts sosa:S_GB_temp,
        sosa:S_G_speed .

:M3 a :Machine,
        :ManufacturingFacility,
        :Resource,
        geo:Feature,
        geo:SpatialObject,
        owl:NamedIndividual,
        owl:Thing,
        sosa:Platform ;
    rdfs:label "Machine M3"@en ;
    :concernBy :S6-1603201294219,
        :S6-1603201294270,
        :S6-1603201299570,
        :S6-1603201299623,
        :S6-1603201299674,
        :S6-1603201299733,
        :S6-1603201309250 ;
    :hasObservableProperty sosa:C_Wtemp,
        sosa:Conv_temp,
        sosa:G_temp,
        sosa:TG_temp ;
    :isPartOf :PL1 ;
    rdfs:comment "Machine individual representing machine M3 of the production line."@en ;
    sosa:hosts sosa:S_C_Wtemp,
        sosa:S_Conv_temp,
        sosa:S_G_temp,
        sosa:S_TG_temp .

:M4 a :Machine,
        :ManufacturingFacility,
        :Resource,
        geo:Feature,
        geo:SpatialObject,
        owl:NamedIndividual,
        owl:Thing,
        sosa:Platform ;
    rdfs:label "Machine M4"@en ;
    :hasObservableProperty sosa:R_Pangle,
        sosa:R_speed ;
    :isPartOf :PL1 ;
    rdfs:comment "Machine individual representing machine M4 of the production line."@en ;
    sosa:hosts sosa:S_R_Pangle,
        sosa:S_R_speed .

:Manager a owl:Class ;
    rdfs:label "Manager"@en ;
    rdfs:comment "A manager is a person responsible for supervising manufacturing operations and responding to detected situations."@en ;
    rdfs:subClassOf :Staff .

:ManufacturingProcess a owl:Class ;
    rdfs:label "Manufacturing Process"@en ;
    rdfs:comment "A manufacturing process is an industrial process carried out within a manufacturing facility to produce or transform products."@en ;
    rdfs:subClassOf :Process .

:Operator a owl:Class ;
    rdfs:label "Operator"@en ;
    rdfs:comment "An operator is a worker responsible for operating machines or performing production tasks."@en ;
    rdfs:subClassOf :Staff .

:Part a owl:Class ;
    rdfs:label "Part"@en ;
    rdfs:comment "A part is a component or piece used in the assembly or production of a product."@en ;
    rdfs:subClassOf :Product .

:Situation-S3 a owl:Class ;
    rdfs:label "Situation S3"@en ;
    rdfs:comment "Situation S3 is a specialized situation class representing a specific contextual state in the manufacturing system."@en ;
    rdfs:subClassOf :Situation .

:Situation-S4 a owl:Class ;
    rdfs:label "Situation S4"@en ;
    rdfs:comment "Situation S4 is a specialized situation class representing a specific contextual state in the manufacturing system."@en ;
    rdfs:subClassOf :Situation .

:Situation-S5 a owl:Class ;
    rdfs:label "Situation S5"@en ;
    rdfs:comment "Situation S5 is a specialized situation class representing a specific contextual state in the manufacturing system."@en ;
    rdfs:subClassOf :Situation .

:Technician a owl:Class ;
    rdfs:label "Technician"@en ;
    rdfs:comment "A technician is a technical specialist responsible for maintaining or repairing equipment."@en ;
    rdfs:subClassOf :Staff .

:concernBy a owl:ObjectProperty ;
    rdfs:label "concerned by"@en ;
    rdfs:comment "Relates a situation or event to an entity, such as a machine, process, or product, that it concerns."@en ;
    rdfs:domain :Resource ;
    rdfs:range :Situation .

:definedOn a owl:ObjectProperty ;
    rdfs:label "defined on"@en ;
    rdfs:comment "Relates a situation or property to the entity or context element on which it is defined."@en ;
    rdfs:domain :Constraint ;
    rdfs:range sosa:ObservableProperty ;
    owl:inverseOf :definedOn_1 .

:hasDescription a owl:DatatypeProperty ;
    rdfs:comment "Links a constraint to its description."@en ;
    rdfs:domain :Constraint ;
    rdfs:range xsd:string .

:hasDuration a owl:ObjectProperty ;
    rdfs:label "has duration"@en ;
    rdfs:comment "Relates an event, process, or situation to the temporal interval during which it occurs."@en ;
    rdfs:domain :Process ;
    rdfs:range time:TemporalEntity .

:hasTime a owl:ObjectProperty ;
    rdfs:label "has time"@en ;
    rdfs:comment "Relates an observation to the temporal entity that represents when it occurred."@en ;
    rdfs:domain sosa:Observation ;
    rdfs:range time:TemporalEntity .

:isInSituation a owl:ObjectProperty ;
    rdfs:label "is in situation"@en ;
    rdfs:comment "Relates an observation to the situation with which it is associated."@en ;
    rdfs:domain sosa:Observation ;
    rdfs:range :Situation .

:isInlocation a owl:ObjectProperty ;
    rdfs:label "is in location"@en ;
    rdfs:comment "Relates a resource to the spatial object in which it is located."@en ;
    rdfs:domain :Resource ;
    rdfs:range geo:SpatialObject .

:isPartOf a owl:ObjectProperty ;
    rdfs:label "is part of"@en ;
    rdfs:comment "Relates an entity to a larger entity of which it is a component."@en ;
    rdfs:domain :ManufacturingFacility ;
    rdfs:range :ManufacturingFacility .

:locatedIn a owl:ObjectProperty ;
    rdfs:label "located in"@en ;
    rdfs:comment "Relates a sensor to the spatial object in which it is located."@en ;
    rdfs:domain sosa:Sensor ;
    rdfs:range geo:SpatialObject .

:operates a owl:ObjectProperty ;
    rdfs:label "operates"@en ;
    rdfs:comment "Relates a staff member or operator to the machine or workstation that they operate."@en ;
    rdfs:domain :Staff ;
    rdfs:range :ManufacturingFacility .

:performsPorcess a owl:ObjectProperty ;
    rdfs:label "performs process"@en ;
    rdfs:comment "Relates a resource to a process that it performs or supports."@en ;
    rdfs:domain :Resource ;
    rdfs:range :Process .

:requiresAction a owl:ObjectProperty ;
    rdfs:label "requires action"@en ;
    rdfs:comment "Relates a situation to an action that should be performed in response to it."@en ;
    rdfs:domain :Situation ;
    rdfs:range :Action .

:situationTime a owl:ObjectProperty ;
    rdfs:label "situation time"@en ;
    rdfs:comment "Relates a situation to the temporal entity that represents when it occurs."@en ;
    rdfs:domain :Situation ;
    rdfs:range time:Interval .

voc:Alarm a owl:Class ;
    rdfs:label "Alarm" .

voc:Cause a owl:Class ;
    rdfs:label "Cause" .

voc:Machine a owl:Class ;
    rdfs:label "Machine" .

voc:Manager a owl:Class ;
    rdfs:label "Manager" .

voc:Operator a owl:Class ;
    rdfs:label "Operator" .

voc:Part a owl:Class ;
    rdfs:label "Part" .

voc:Product a owl:Class ;
    rdfs:label "Product" .

voc:Situation a owl:Class ;
    rdfs:label "Situation" .

voc:alarm a owl:Class ;
    rdfs:label "alarm" .

voc:component a owl:Class ;
    rdfs:label "component" .

voc:hasCause a owl:ObjectProperty ;
    rdfs:label "hasCause" .

voc:hasIntervention a owl:ObjectProperty ;
    rdfs:label "hasIntervention" .

voc:hasMachine a owl:ObjectProperty ;
    rdfs:label "hasMachine" .

voc:hasResponsible a owl:ObjectProperty ;
    rdfs:label "hasResponsible" .

voc:machine a owl:Class ;
    rdfs:label "machine" .

voc:operator a owl:Class ;
    rdfs:label "operator" .

voc:part a owl:Class ;
    rdfs:label "part" .

voc:responsibleFor a owl:ObjectProperty ;
    rdfs:label "responsibleFor" .

geo:asGML a owl:DatatypeProperty ;
    rdfs:comment "Links a geometry to its GML serialization."@en ;
    rdfs:domain geo:Geometry ;
    rdfs:range geo:gmlLiteral .

geo:asWKT a owl:DatatypeProperty ;
    rdfs:comment "Links a geometry to its WKT serialization."@en ;
    rdfs:domain geo:Geometry ;
    rdfs:range geo:wktLiteral .

geo:hasGeometry a owl:ObjectProperty ;
    rdfs:label "has geometry"@en ;
    rdfs:comment "Relates a feature to the geometry that represents its spatial extent."@en ;
    rdfs:domain geo:Feature ;
    rdfs:range geo:Geometry .

geo:rcc8dc a owl:ObjectProperty ;
    rdfs:label "disconnected"@en ;
    rdfs:comment "Relates two spatial regions that are disconnected and share no common point."@en ;
    rdfs:domain geo:SpatialObject ;
    rdfs:range geo:SpatialObject .

geo:rcc8ec a owl:ObjectProperty ;
    rdfs:label "externally connected"@en ;
    rdfs:comment "Relates two spatial regions that touch along their boundary but whose interiors do not overlap."@en ;
    rdfs:domain geo:SpatialObject ;
    rdfs:range geo:SpatialObject .

geo:rcc8eq a owl:ObjectProperty ;
    rdfs:label "equals"@en ;
    rdfs:comment "Relates two spatial regions that have exactly the same spatial extent."@en ;
    rdfs:domain geo:SpatialObject ;
    rdfs:range geo:SpatialObject .

geo:rcc8ntpp a owl:ObjectProperty ;
    rdfs:label "non-tangential proper part"@en ;
    rdfs:comment "Relates a spatial region that is completely inside another region without touching its boundary."@en ;
    rdfs:domain geo:SpatialObject ;
    rdfs:range geo:SpatialObject .

geo:rcc8ntppi a owl:ObjectProperty ;
    rdfs:label "non-tangential proper part inverse"@en ;
    rdfs:comment "Relates a spatial region that completely contains another region whose boundary it does not touch."@en ;
    rdfs:domain geo:SpatialObject ;
    rdfs:range geo:SpatialObject .

geo:rcc8po a owl:ObjectProperty ;
    rdfs:label "partially overlapping"@en ;
    rdfs:comment "Relates two spatial regions whose interiors overlap, while neither region contains the other."@en ;
    rdfs:domain geo:SpatialObject ;
    rdfs:range geo:SpatialObject .

geo:rcc8tpp a owl:ObjectProperty ;
    rdfs:label "tangential proper part"@en ;
    rdfs:comment "Relates a spatial region that is inside another region and touches its boundary."@en ;
    rdfs:domain geo:SpatialObject ;
    rdfs:range geo:SpatialObject .

geo:rcc8tppi a owl:ObjectProperty ;
    rdfs:label "tangential proper part inverse"@en ;
    rdfs:comment "Relates a spatial region that contains another region and touches its boundary."@en ;
    rdfs:domain geo:SpatialObject ;
    rdfs:range geo:SpatialObject .

time:after a owl:ObjectProperty ;
    rdfs:label "after"@en ;
    rdfs:comment "Relates a temporal entity that occurs after another temporal entity."@en ;
    rdfs:domain time:TemporalEntity ;
    rdfs:range time:TemporalEntity .

time:before a owl:ObjectProperty ;
    rdfs:label "before"@en ;
    rdfs:comment "Relates a temporal entity that occurs before another temporal entity."@en ;
    rdfs:domain time:TemporalEntity ;
    rdfs:range time:TemporalEntity .

time:hasBeginning a owl:ObjectProperty ;
    rdfs:label "has beginning"@en ;
    rdfs:comment "Relates a temporal interval to the instant that marks its beginning."@en ;
    rdfs:domain time:TemporalEntity ;
    rdfs:range time:Instant .

time:hasEnd a owl:ObjectProperty ;
    rdfs:label "has end"@en ;
    rdfs:comment "Relates a temporal interval to the instant that marks its end."@en ;
    rdfs:domain time:TemporalEntity ;
    rdfs:range time:Instant .

time:inXSDDateTimeStamp a owl:DatatypeProperty ;
    rdfs:comment "Position of an instant in which the time-zone field is mandatory."@en ;
    rdfs:domain time:Instant ;
    rdfs:range <https://www.w3.org/TR/xmlschema11-2/#dateTimeStamp> .

time:inside a owl:ObjectProperty ;
    rdfs:label "inside"@en ;
    rdfs:comment "Relates a temporal instant or interval that occurs within another interval."@en ;
    rdfs:domain time:Interval ;
    rdfs:range time:Instant .

time:intervalAfter a owl:ObjectProperty ;
    rdfs:label "interval after"@en ;
    rdfs:comment "Relates a time interval that occurs completely after another interval."@en ;
    rdfs:domain time:Interval ;
    rdfs:range time:Interval .

time:intervalBefore a owl:ObjectProperty ;
    rdfs:label "interval before"@en ;
    rdfs:comment "Relates a time interval that occurs completely before another interval."@en ;
    rdfs:domain time:Interval ;
    rdfs:range time:Interval .

time:intervalContains a owl:ObjectProperty ;
    rdfs:label "interval contains"@en ;
    rdfs:comment "Relates a time interval that fully contains another interval."@en ;
    rdfs:domain time:Interval ;
    rdfs:range time:Interval .

time:intervalDisjoint a owl:ObjectProperty ;
    rdfs:label "interval disjoint"@en ;
    rdfs:comment "Relates two temporal intervals that do not overlap in time."@en ;
    rdfs:domain time:Interval ;
    rdfs:range time:Interval .

time:intervalDuring a owl:ObjectProperty ;
    rdfs:label "interval during"@en ;
    rdfs:comment "Relates an interval that starts after another interval begins and ends before it ends."@en ;
    rdfs:domain time:Interval ;
    rdfs:range time:Interval .

time:intervalEquals a owl:ObjectProperty ;
    rdfs:label "interval equals"@en ;
    rdfs:comment "Relates two time intervals that have exactly the same temporal extent."@en ;
    rdfs:domain time:Interval ;
    rdfs:range time:Interval .

time:intervalFinishedBy a owl:ObjectProperty ;
    rdfs:label "interval finished by"@en ;
    rdfs:comment "Relates an interval that ends at the same time as another interval but starts earlier."@en ;
    rdfs:domain time:Interval ;
    rdfs:range time:Interval .

time:intervalFinishes a owl:ObjectProperty ;
    rdfs:label "interval finishes"@en ;
    rdfs:comment "Relates an interval that ends at the same time as another interval but starts later."@en ;
    rdfs:domain time:Interval ;
    rdfs:range time:Interval .

time:intervalIn a owl:ObjectProperty ;
    rdfs:label "interval in"@en ;
    rdfs:comment "Relates an interval that is contained within another interval, without requiring both boundaries to coincide."@en ;
    rdfs:domain time:Interval ;
    rdfs:range time:Interval .

time:intervalMeets a owl:ObjectProperty ;
    rdfs:label "interval meets"@en ;
    rdfs:comment "Relates an interval that ends exactly when another interval begins."@en ;
    rdfs:domain time:Interval ;
    rdfs:range time:Interval .

time:intervalMetBy a owl:ObjectProperty ;
    rdfs:label "interval met by"@en ;
    rdfs:comment "Relates an interval that begins exactly when another interval ends."@en ;
    rdfs:domain time:Interval ;
    rdfs:range time:Interval .

time:intervalOverlaps a owl:ObjectProperty ;
    rdfs:label "interval overlaps"@en ;
    rdfs:comment "Relates an interval that overlaps another interval without either interval containing the other."@en ;
    rdfs:domain time:Interval ;
    rdfs:range time:Interval .

time:intervalStartedBy a owl:ObjectProperty ;
    rdfs:label "interval started by"@en ;
    rdfs:comment "Relates an interval that starts at the same time as another interval but ends later."@en ;
    rdfs:domain time:Interval ;
    rdfs:range time:Interval .

time:intervalStarts a owl:ObjectProperty ;
    rdfs:label "interval starts"@en ;
    rdfs:comment "Relates an interval that starts at the same time as another interval but ends sooner."@en ;
    rdfs:domain time:Interval ;
    rdfs:range time:Interval .

sosa:hasFeatureOfInterest a owl:ObjectProperty ;
    rdfs:label "has feature of interest"@en ;
    rdfs:comment "Relates an observation to the entity whose property is being observed."@en ;
    rdfs:domain sosa:Observation ;
    rdfs:range sosa:FeatureOfInterest .

sosa:hasResult a owl:ObjectProperty ;
    rdfs:label "has result"@en ;
    rdfs:comment "Relates an observation to the result that it produced."@en ;
    rdfs:domain sosa:Observation ;
    rdfs:range sosa:Result .

sosa:hasSimpleResult a owl:DatatypeProperty ;
    rdfs:comment "Links an obervation to its result, which contains a value representing the value associated with the observed Property."@en ;
    rdfs:domain sosa:Observation ;
    rdfs:range xsd:integer .

ssn:hasProperty a owl:ObjectProperty ;
    rdfs:label "has property"@en ;
    rdfs:comment "Relates an entity to one of its properties."@en ;
    rdfs:domain sosa:FeatureOfInterest ;
    rdfs:range ssn:Property .

:Action a owl:Class ;
    rdfs:label "Action"@en ;
    rdfs:comment "An action is an operation or intervention performed in response to a detected situation in the manufacturing system."@en ;
    rdfs:subClassOf owl:Thing .

:C_1 a :Constraint,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Constraint C1"@en ;
    :definedOn sosa:OilTemp ;
    :hasDescription "OilTemp > 40°C" ;
    rdfs:comment "Constraint individual defining the condition \"OilTemp > 40°C\"."@en .

:C_10 a :Constraint,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Constraint C10"@en ;
    :definedOn sosa:G_speed ;
    :hasDescription "Generator speed < 500rpm" ;
    rdfs:comment "Constraint individual defining the condition \"Generator speed < 500rpm\"."@en .

:C_11 a :Constraint,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Constraint C11"@en ;
    :definedOn sosa:E_temp ;
    :hasDescription "Environment temp. < 25°C" ;
    rdfs:comment "Constraint individual defining the condition \"Environment temp. < 25°C\"."@en .

:C_12 a :Constraint,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Constraint C12"@en ;
    :definedOn sosa:PowerOutput ;
    :hasDescription "Power output > 2000kW" ;
    rdfs:comment "Constraint individual defining the condition \"Power output > 2000kW\"."@en .

:C_13 a :Constraint,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Constraint C13"@en ;
    :definedOn sosa:PowerOutput ;
    :hasDescription "Power output < 500kW" ;
    rdfs:comment "Constraint individual defining the condition \"Power output < 500kW\"."@en .

:C_14 a :Constraint,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Constraint C14"@en ;
    :definedOn sosa:PowerOutput ;
    :hasDescription "Power output < 200kW" ;
