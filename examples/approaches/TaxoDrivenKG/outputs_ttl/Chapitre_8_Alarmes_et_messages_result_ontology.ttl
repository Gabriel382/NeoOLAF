    rdfs:comment "A platform is an entity that hosts sensors, actuators, samplers, or other platforms."@en ;
    rdfs:subClassOf geo:Feature .

:hasCause a owl:ObjectProperty ;
    rdfs:label "has cause"@en ;
    rdfs:comment "Relates a situation to the cause responsible for triggering or explaining it."@en ;
    rdfs:domain :Situation ;
    rdfs:range :Cause .

:ManufacturingFacility a owl:Class ;
    rdfs:label "Manufacturing Facility"@en ;
    rdfs:comment "A manufacturing facility is a physical environment where manufacturing processes take place."@en ;
    rdfs:subClassOf :Resource,
        sosa:Platform .

:Resource a owl:Class ;
    rdfs:label "Resource"@en ;
    rdfs:comment "A resource is an entity used during manufacturing processes, such as a machine, material, or human resource."@en ;
    rdfs:subClassOf geo:Feature ;
    owl:equivalentClass sosa:Platform .

