    rdfs:subClassOf owl:Thing .

:Constraint a owl:Class ;
    rdfs:label "Constraint"@en ;
    rdfs:comment "A constraint is a condition or rule that restricts or defines acceptable states of a process, resource, or situation."@en ;
    rdfs:subClassOf owl:Thing .

:Situation a owl:Class ;
    rdfs:label "Situation"@en ;
    rdfs:comment "A situation is a contextual state describing conditions in a manufacturing environment based on observations, processes, and contextual factors."@en ;
    rdfs:subClassOf owl:Thing .

time:Interval a owl:Class ;
    rdfs:label "Interval"@en ;
    rdfs:comment "An interval is a temporal extent with a beginning and an end."@en ;
    rdfs:subClassOf time:TemporalEntity .

sosa:Observation a owl:Class ;
    rdfs:label "Observation"@en ;
    rdfs:comment "An observation is an event in which a sensor measures or estimates the value of an observable property of a feature of interest."@en ;
    rdfs:subClassOf owl:Thing .

time:TemporalEntity a owl:Class ;
    rdfs:label "Temporal Entity"@en ;
    rdfs:comment "A temporal entity is a temporal interval or instant used to represent the time of an observation or situation."@en ;
    rdfs:subClassOf owl:Thing .

time:Instant a owl:Class ;
    rdfs:label "Instant"@en ;
    rdfs:comment "An instant is a specific point in time."@en ;
    rdfs:subClassOf time:TemporalEntity .

[] a swrl:Imp ;
    swrl:body [ a swrl:AtomList ;
            rdf:first [ a swrl:ClassAtom ;
                    swrl:argument1 :sit ;
                    swrl:classPredicate :Situation-S10 ] ;
            rdf:rest () ] ;
    swrl:head [ a swrl:AtomList ;
            rdf:first [ a swrl:IndividualPropertyAtom ;
                    swrl:argument1 :sit ;
                    swrl:argument2 :Severe_Obstruction_in_the_Cooling_System ;
                    swrl:propertyPredicate :hasCause ] ;
            rdf:rest () ] .

