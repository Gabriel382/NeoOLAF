                    swrl:argument1 :sit ;
                    swrl:argument2 :Minor_Obstruction_in_the_Cooling_System ;
                    swrl:propertyPredicate :hasCause ] ;
            rdf:rest () ] .

[] a swrl:Imp ;
    swrl:body [ a swrl:AtomList ;
            rdf:first [ a swrl:ClassAtom ;
                    swrl:argument1 :sit ;
                    swrl:classPredicate :Situation-S13 ] ;
            rdf:rest () ] ;
    swrl:head [ a swrl:AtomList ;
            rdf:first [ a swrl:IndividualPropertyAtom ;
                    swrl:argument1 :sit ;
                    swrl:argument2 :DeteriotatedGears ;
                    swrl:propertyPredicate :hasCause ] ;
            rdf:rest () ] .

[] a swrl:Imp ;
    swrl:body [ a swrl:AtomList ;
            rdf:first [ a swrl:ClassAtom ;
                    swrl:argument1 :sit ;
                    swrl:classPredicate :Situation-S6 ] ;
            rdf:rest () ] ;
    swrl:head [ a swrl:AtomList ;
            rdf:first [ a swrl:IndividualPropertyAtom ;
                    swrl:argument1 :sit ;
                    swrl:argument2 :PollutedFilters ;
                    swrl:propertyPredicate :hasCause ] ;
            rdf:rest () ] .

[] a swrl:Imp ;
    swrl:body [ a swrl:AtomList ;
            rdf:first [ a swrl:ClassAtom ;
                    swrl:argument1 :sit ;
