:C_7 a :Constraint,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Constraint C7"@en ;
    :definedOn sosa:P_temp ;
    :hasDescription "Platform temp. > 40°C" ;
    rdfs:comment "Constraint individual defining the condition \"Platform temp. > 40°C\"."@en .

:C_8 a :Constraint,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Constraint C8"@en ;
