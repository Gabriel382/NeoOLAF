@prefix neo: <http://neoolaf.org/resource/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://neoolaf.org/resource/concept/concept_00000> a owl:Class ;
    rdfs:label "CNC" ;
    neo:conceptKind "IndustrialEquipment" ;
    neo:parentHint "MachineTool" ;
    rdfs:comment "A computer-controlled system for automating the machining process." .

<http://neoolaf.org/resource/concept/concept_00001> a owl:Class ;
    rdfs:label "PLC" ;
    neo:conceptKind "component" ;
    neo:parentHint "IndustrialEquipment" ;
    rdfs:comment "A programmable logic controller used to control machinery and processes." .

<http://neoolaf.org/resource/concept/concept_00002> a owl:Class ;
    rdfs:label "Cycle" ;
    neo:conceptKind "process" ;
    neo:parentHint "TemporalEntity" ;
    rdfs:comment "A recurring sequence of events or phenomena." .

<http://neoolaf.org/resource/concept/concept_00003> a owl:Class ;
    rdfs:label "Axes" ;
    neo:conceptKind "component" ;
    neo:parentHint "MachinePart" ;
    rdfs:comment "Movable parts of a machine." .

<http://neoolaf.org/resource/concept/concept_00004> a owl:Class ;
    rdfs:label "Reset" ;
    neo:conceptKind "action" ;
    neo:parentHint "Action" ;
    rdfs:comment "An action that returns a machine or system to its default state." .

<http://neoolaf.org/resource/concept/concept_00005> a owl:Class ;
    rdfs:label "UrgencyActive" ;
    neo:conceptKind "alarm_type" ;
    neo:parentHint "Alarm" ;
    rdfs:comment "A type of alarm indicating an urgent situation requiring immediate attention." .

<http://neoolaf.org/resource/relation/ont_rel_00000> a owl:ObjectProperty ;
    rdfs:label "emittedBy" ;
    neo:domainHint "AlarmEvent" ;
    neo:rangeHint "Device" ;
    rdfs:comment "Relates an alarm or emitted signal to the system or device that emits it." ;
    rdfs:domain "AlarmEvent" ;
    rdfs:range "Device" .

