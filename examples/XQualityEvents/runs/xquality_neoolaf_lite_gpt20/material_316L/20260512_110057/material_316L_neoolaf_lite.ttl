    rdfs:comment "Indicates spindle power stays unchanged when 316L grade is used" .

neol:316lGradeInsteadOf303StainlessSteel neol:increases neol:spindlePowerAI1 .
neol:material_316L_statement_0001 rdf:type neol:CandidateTriple ;
    neol:subject neol:316lGradeInsteadOf303StainlessSteel ;
    neol:predicate neol:increases ;
    neol:object neol:spindlePowerAI1 ;
    rdfs:comment "Spindle power increases when 316L grade => OK" ;
    neol:page "6" ;
    neol:confidence "0.9" ;
    neol:condition "material_316L" ;
    neol:sensor "AI1" ;
    neol:feature "power" ;
    neol:direction "increase" ;
    neol:operation "unknown" .

