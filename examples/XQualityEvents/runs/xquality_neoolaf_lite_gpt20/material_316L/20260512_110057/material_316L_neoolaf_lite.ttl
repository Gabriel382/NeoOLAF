neol:316lGradeInsteadOf303StainlessSteel rdf:type rdfs:Class ;
    rdfs:label "316L grade instead of 303 stainless steel" ;
    rdfs:comment "Abnormal material grade used in machining" .

neol:spindlePowerAI1 rdf:type rdfs:Class ;
    rdfs:label "Spindle Power (AI1)" ;
    rdfs:comment "Measurement of spindle power captured by sensor AI1" .

neol:cuttingForceFz rdf:type rdfs:Class ;
    rdfs:label "Cutting Force (Fz)" ;
    rdfs:comment "Force applied in the cutting direction" .

neol:vibrationRMSVib1 rdf:type rdfs:Class ;
    rdfs:label "Vibration RMS (Vib1)" ;
    rdfs:comment "Root‑mean‑square vibration measured by sensor Vib1" .

neol:audioRMSVib11 rdf:type rdfs:Class ;
    rdfs:label "Audio RMS (Vib11)" ;
    rdfs:comment "Root‑mean‑square audio level measured by sensor Vib11" .

neol:increases rdf:type rdf:Property ;
    rdfs:label "INCREASES" ;
    rdfs:comment "Indicates spindle power rises when 316L grade is used" .

