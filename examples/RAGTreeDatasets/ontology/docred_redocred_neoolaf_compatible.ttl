dr:BLANK a owl:Class ;
    rdfs:label "BLANK" ;
    rdfs:comment "Represents a placeholder or unknown entity in DocRED" .

dr:NUM a owl:Class ;
    rdfs:label "NUM" ;
    rdfs:comment "A number, quantity, or countable concept." .

dr:TIME a owl:Class ;
    rdfs:label "TIME" ;
    rdfs:comment "A temporal point or period such as a date or historical time." .

