@prefix ex: <https://example.org/docred/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# This is a fixed reference ontology used only by the sample test.
ex:P19 a owl:ObjectProperty ;
    rdfs:label "place of birth" .

ex:P131 a owl:ObjectProperty ;
    rdfs:label "located in the administrative territorial entity" .
