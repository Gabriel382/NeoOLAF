    },
    "preserve_layer01_surface_form_as_candidate_label": true,
    "do_not_merge_distinct_named_mentions_by_generic_type": true
  },
  "evaluation": {
    "dataset": "DocRED",
    "strict_relation_match": true,
    "gold_is_analysis_only": true,
    "report_native_and_mapped_outputs_separately": true,
    "variant": "relaxed_candidate_promotion"
  },
  "orchestration": {
    "mode": "pipeline",
    "document_workers": 1,
    "max_concurrency_layer01": 1,
    "max_concurrency_layer02": 4,
    "max_concurrency_layer03": 4,
    "max_concurrency_layer04": 4,
    "max_concurrency_layer05": 4,
    "max_concurrency_layer06": 4,
    "max_concurrency_layer07": 4,
    "max_concurrency_layer08": 4,
    "max_concurrency_layer09": 4,
    "max_concurrency_layer10": 4,
    "max_concurrency_layer11": 4,
    "max_concurrency_layer12": 4,
    "retry_failed_calls": 2,
    "retry_sleep_seconds": 2.0
  },
  "anti_cheating": {
    "direct_docred_extraction": false,
    "raw_text_direct_fallback": false,
    "source_entity_anchoring": false,
    "gold_relation_hints": false,
    "post_extraction_relation_closure": false,
    "src_changes": false
  },
  "diagnostics": {
    "trace_from_layer01": true,
    "separate_native_from_mapped": true,
    "record_valid_but_unannotated_relations": true,
    "note": "Layer 3 uses the existing role-based strategy so canonical labels remain source mentions rather than generic class names."
  }
}
